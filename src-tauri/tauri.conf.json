{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "concrnt-world",
  "version": "0.1.6",
  "identifier": "world.concrnt.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "world-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "autoIncrementVersionCode": false,
      "versionCode": 2026071401
    }
  }
}
