{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "barcode-scanner:allow-scan",
    "barcode-scanner:allow-cancel",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://*",
          "app": true
        }
      ]
    }
  ]
}
